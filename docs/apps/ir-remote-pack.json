{
  "schema": "tabforge.mini-app.v1",
  "id": "ir-remote-pack",
  "name": "IR Remote Pack",
  "version": "0.1.1",
  "surface": "tab5",
  "summary": "Starter NEC remote macro pack for the Tab5 Grove IR unit controls.",
  "store": {
    "category": "IR",
    "icon": "IR",
    "status": "stable",
    "minFirmware": "0.1.21",
    "releaseNotes": "Adds v1 store metadata for individual updates."
  },
  "storage": {
    "root": "/tabforge/apps/ir-remote-pack",
    "writes": [
      "/tabforge/ir/macros.json"
    ]
  },
  "permissions": {
    "irSend": true,
    "irLearn": true,
    "nativeCode": false
  },
  "actions": [
    {
      "id": "nec-power",
      "label": "Power",
      "protocol": "nec",
      "address": "0x00ff",
      "command": "0x45"
    },
    {
      "id": "nec-mute",
      "label": "Mute",
      "protocol": "nec",
      "address": "0x00ff",
      "command": "0x47"
    },
    {
      "id": "nec-volume-up",
      "label": "Volume Up",
      "protocol": "nec",
      "address": "0x00ff",
      "command": "0x09"
    },
    {
      "id": "nec-volume-down",
      "label": "Volume Down",
      "protocol": "nec",
      "address": "0x00ff",
      "command": "0x15"
    }
  ]
}
