{
  "schema": "tabforge.mini-app.v1",
  "id": "cardputer-keyboard",
  "name": "Cardputer Controller",
  "version": "0.2.0",
  "surface": "tab5",
  "summary": "Use an M5Stack Cardputer as a handheld keyboard and app controller for TabForge over Grove UART or USB CDC.",
  "store": {
    "category": "Input",
    "icon": "KEY",
    "status": "stable",
    "minFirmware": "0.1.26",
    "releaseNotes": "Adds Cardputer app pages for launcher, mesh, IR, system, SDR, and app-store controls while keeping keyboard text entry."
  },
  "storage": {
    "root": "/tabforge/apps/cardputer-keyboard",
    "writes": [
      "/tabforge/logs/events.jsonl",
      "/tabforge/apps/cardputer-keyboard/state.json"
    ]
  },
  "permissions": {
    "keyboardInput": true,
    "usbHost": true,
    "groveUart": true,
    "nativeCode": false
  },
  "actions": [
    {
      "id": "open-keyboard",
      "label": "Open Controller",
      "mode": "cardputer-open"
    },
    {
      "id": "power-link",
      "label": "Power Link",
      "mode": "cardputer-power"
    },
    {
      "id": "probe-cardputer",
      "label": "Probe",
      "mode": "cardputer-probe"
    },
    {
      "id": "clear-stats",
      "label": "Clear",
      "mode": "cardputer-clear"
    }
  ]
}
