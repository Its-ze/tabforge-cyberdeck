{
  "schema": "tabforge.mini-app.v1",
  "id": "cardputer-keyboard",
  "name": "Cardputer AppDeck",
  "version": "0.3.0",
  "surface": "tab5",
  "summary": "Use an M5Stack Cardputer as a handheld keyboard, scrollable app deck, Meshtastic GPS controller, and attachment remote over Grove UART or USB CDC.",
  "store": {
    "category": "Input",
    "icon": "KEY",
    "status": "stable",
    "minFirmware": "0.1.27",
    "releaseNotes": "Renames the companion to AppDeck and adds scrollable app/action pages for Meshtastic GPS, attachments, mini apps, Wi-Fi/OTA, files, IR, recorder, and RTL-SDR."
  },
  "storage": {
    "root": "/tabforge/apps/cardputer-keyboard",
    "writes": [
      "/tabforge/logs/events.jsonl",
      "/tabforge/apps/cardputer-keyboard/state.json"
    ]
  },
  "permissions": {
    "keyboardInput": true,
    "usbHost": true,
    "groveUart": true,
    "nativeCode": false,
    "appDeckControls": true,
    "meshGpsControls": true,
    "attachmentControls": true
  },
  "actions": [
    {
      "id": "open-keyboard",
      "label": "Open AppDeck",
      "mode": "cardputer-open"
    },
    {
      "id": "power-link",
      "label": "Power Link",
      "mode": "cardputer-power"
    },
    {
      "id": "probe-cardputer",
      "label": "Probe",
      "mode": "cardputer-probe"
    },
    {
      "id": "clear-stats",
      "label": "Clear",
      "mode": "cardputer-clear"
    }
  ]
}
